# Konfigurasi Supabase
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
VITE_SUPABASE_STORAGE_BUCKET="site-media"
VITE_SUPABASE_CAMPAIGN_ASSETS_BUCKET="campaign-assets"

# Konfigurasi Cloudflare Turnstile (anti-bot widget)
# Dapatkan site key dari: https://dash.cloudflare.com → Turnstile
VITE_TURNSTILE_SITE_KEY="your-turnstile-site-key"

# Secret khusus Supabase Edge Functions. Atur dengan:
# supabase secrets set TURNSTILE_SECRET_KEY=your-turnstile-secret ALLOWED_ORIGINS=https://www.sekolahtanahair.org,https://sekolahtanahair.org,http://localhost:3000,http://127.0.0.1:3000
TURNSTILE_SECRET_KEY="your-turnstile-secret"
ALLOWED_ORIGINS="https://www.sekolahtanahair.org,https://sekolahtanahair.org,http://localhost:3000,http://127.0.0.1:3000"
